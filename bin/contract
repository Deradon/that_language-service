#!/usr/bin/env bash
#
# Contract test: this service against the core that_language gem.
#
#   bin/contract [port]
#
# This service exposes the core gem's API as eight HTTP endpoints. Parity is a
# convention maintained by hand, with nothing enforcing it. This checks that the
# convention still holds, by starting a real service from this working tree and
# comparing every endpoint against the core gem.
#
# Why it is shaped this way, since none of it is arbitrary:
#
#   - Two processes, because one of them has to be an HTTP server. The probe
#     that reads it is stdlib-only and never loads that_language, so it cannot
#     accidentally answer from the gem it is supposed to be checking.
#
#   - A real service rather than rack-test, because the existing suite already
#     exercises the app in-process and cannot catch this class of bug. It
#     asserts what the app does; a contract test asserts what the core gem does.
#
#   - No Docker. that_language is on rubygems and this gem ships a config.ru, so
#     the service can be started directly. Nothing is pushed to a registry, so a
#     container here would mean building an image from another repository.
#
#   - Not the deployed endpoint. A test that needs someone's production box is
#     not a test.
#
# What is being compared, and what equality means when JSON has no symbols, is
# documented in contract/canonical.rb. Read that before changing any of this.
#
# Assertions live in this script rather than inline in the workflow so a failure
# reproduces locally instead of only by pushing.

set -euo pipefail

cd "$(dirname "$0")/.."

PORT="${1:-4567}"
BASE="http://127.0.0.1:${PORT}"
GEMFILES="contract/gemfiles"
WORK="$(mktemp -d)"
SERVICE_PID=""

cleanup() {
  if [ -n "${SERVICE_PID}" ]; then
    # Children first. `bundle exec` does not reliably replace itself with puma,
    # so signalling only SERVICE_PID can reap the wrapper and orphan the server
    # -- which leaves the port bound after this script exits. That is not a
    # tidiness problem: the next run then polls a stale service and compares
    # against whatever code *it* was started with, silently. Found exactly that
    # way on 2026-07-20.
    pkill -P "${SERVICE_PID}" 2>/dev/null || true
    kill "${SERVICE_PID}" 2>/dev/null || true
    wait "${SERVICE_PID}" 2>/dev/null || true
  fi
  rm -rf "${WORK}"
}
trap cleanup EXIT

# Refuse to run against a port we do not own. The readiness poll below cannot
# tell our service from someone else's, so without this check an occupied port
# turns the whole run into a test of an unrelated process -- passing or failing
# for reasons that have nothing to do with this working tree.
if curl -fsS -o /dev/null "${BASE}/version" 2>/dev/null; then
  echo "something is already listening on ${BASE} -- refusing to run." >&2
  echo "The probes would compare against that process, not this working tree." >&2
  echo "Stop it, or pass a different port: bin/contract 4600" >&2
  exit 1
fi

# --- 1. Two isolated bundles ------------------------------------------------
#
# core comes from rubygems and is the reference implementation; the service
# comes from this working tree. That asymmetry is load-bearing -- see the
# comment in service.gemfile.
echo "bundles"
for gemfile in core service; do
  BUNDLE_GEMFILE="${GEMFILES}/${gemfile}.gemfile" bundle install --quiet
  echo "  ok    ${gemfile}"
done

# --- 2. Start the service ---------------------------------------------------
#
# APP_ENV=production is pinned deliberately. Sinatra 4's
# Rack::Protection::HostAuthorization allow-lists localhost only in the
# development environment; production applies no allow-list. The deployed image
# pins this for the same reason and a hand-rolled boot must not forget it.
echo "service"
BUNDLE_GEMFILE="${GEMFILES}/service.gemfile" \
  APP_ENV=production RACK_ENV=production \
  bundle exec puma --bind "tcp://127.0.0.1:${PORT}" contract/config.ru \
  >"${WORK}/service.log" 2>&1 &
SERVICE_PID=$!

# contract/config.ru warms the wordlist cache before puma binds, so a service
# that answers at all is warm. Poll rather than sleep -- the warm-up is ~0.9 s
# but bundler and boot are not, and a fixed sleep is either flaky or slow.
for _ in $(seq 1 60); do
  if curl -fsS -o /dev/null "${BASE}/version" 2>/dev/null; then break; fi
  if ! kill -0 "${SERVICE_PID}" 2>/dev/null; then
    echo "service exited during boot:" >&2
    cat "${WORK}/service.log" >&2
    exit 1
  fi
  sleep 1
done

if ! curl -fsS -o /dev/null "${BASE}/version"; then
  echo "service never answered on ${BASE}/version:" >&2
  cat "${WORK}/service.log" >&2
  exit 1
fi
echo "  ok    answers on ${BASE}/version"

# --- 3. Probe both sides ----------------------------------------------------
#
# Both probes emit the same canonical format from contract/canonical.rb, which
# they share rather than each implementing -- the flattening and the invariants
# are exactly the logic that must not differ between the two sides.
echo "probes"
BUNDLE_GEMFILE="${GEMFILES}/core.gemfile" \
  bundle exec ruby contract/probe_core.rb >"${WORK}/core.txt"
echo "  ok    core gem"

BUNDLE_GEMFILE="${GEMFILES}/service.gemfile" \
  bundle exec ruby contract/probe_service.rb "${BASE}" >"${WORK}/service.txt"
echo "  ok    service"

# --- 4. The diff is the assertion -------------------------------------------
echo
if diff -u --label "core gem" --label "service" "${WORK}/core.txt" "${WORK}/service.txt"; then
  echo "contract holds: $(wc -l <"${WORK}/core.txt" | tr -d ' ') probes identical"
else
  echo
  echo "CONTRACT VIOLATED -- the service does not match the core gem." >&2
  echo "Each endpoint must serialize exactly the JSON projection of the core" >&2
  echo "gem's return value. See contract/canonical.rb." >&2
  exit 1
fi
